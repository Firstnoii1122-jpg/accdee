# ================================================
# .env.example — ตัวอย่างตัวแปรที่ต้องตั้งค่า
# คัดลอกไฟล์นี้ไปเป็น .env แล้วใส่ค่าจริง
# ================================================

# ----- Server -----
PORT=3000

# ----- Database -----
# Railway จะ inject ค่าพวกนี้ให้อัตโนมัติ (MYSQLHOST, MYSQLUSER ฯลฯ)
# ถ้ารัน local ให้ใส่ค่าด้านล่างนี้แทน
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=[SET_IN_RAILWAY_OR_LOCAL_ENV]
DB_NAME=accdee_site

# ----- JWT -----
# ต้องเปลี่ยนเป็น string สุ่มยาวๆ ห้ามใช้ค่าตัวอย่างนี้จริง
JWT_SECRET=[SET_IN_RAILWAY_OR_LOCAL_ENV]
JWT_EXPIRES_IN=15m

# ----- Admin -----
# รหัสผ่านของ admin ที่จะสร้างอัตโนมัติตอน server start ครั้งแรก
ADMIN_PASSWORD=[SET_IN_RAILWAY_OR_LOCAL_ENV]
# email ที่รับ notification เมื่อมีสมาชิกใหม่สมัคร
ADMIN_EMAIL=email_admin@gmail.com

# ----- URL เว็บไซต์ -----
# ใส่ URL จริงที่ได้จาก Railway เช่น https://accdee-xxx.up.railway.app
FRONTEND_URL=https://your-railway-url.up.railway.app
SITE_URL=https://your-railway-url.up.railway.app

# ----- ข้อมูลรับเงิน -----
PROMPTPAY_NUMBER=0812345678
BANK_NAME=กสิกรไทย
BANK_ACCOUNT_NUMBER=1234567890
BANK_ACCOUNT_NAME=ชื่อ-นามสกุล

# ----- Cloudinary (อัปโหลดรูปสลิปการโอนเงิน) -----
# สมัครฟรีที่ https://cloudinary.com → Dashboard จะเห็นค่าทั้ง 3 นี้
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ----- Gmail (ส่ง email แจ้งสมาชิก) -----
# ต้องเปิด 2FA ใน Google Account ก่อน
# แล้วไปสร้าง App Password ที่ myaccount.google.com → Security → App passwords
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=[SET_IN_RAILWAY_OR_LOCAL_ENV]

# ----- Telegram Bot (แจ้งเตือน admin แบบ real-time) -----
# 1. ไปคุยกับ @BotFather ใน Telegram → /newbot → ได้ TOKEN
# 2. เพิ่ม bot เข้า group หรือ channel → ได้ CHAT_ID
TELEGRAM_BOT_TOKEN=[SET_IN_RAILWAY_OR_LOCAL_ENV]
TELEGRAM_CHAT_ID=-1001234567890
