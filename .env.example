# ================================================
# .env.example — ตัวอย่างตัวแปรที่ต้องตั้งค่า
# คัดลอกไฟล์นี้ไปเป็น .env แล้วใส่ค่าจริง
# ================================================

# PORT ที่ server รัน
PORT=3000

# ข้อมูลเชื่อมต่อ MySQL
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=รหัสผ่าน_mysql_ของคุณ
DB_NAME=accdee_site

# JWT Secret — เปลี่ยนเป็น string ยาวๆ สุ่มขึ้นมาเอง
JWT_SECRET=เปลี่ยนเป็น_string_ลับยาวๆ_ของคุณ
JWT_EXPIRES_IN=7d

# ข้อมูลรับเงิน — ใส่ของจริง
PROMPTPAY_NUMBER=เบอร์พร้อมเพย์
BANK_NAME=ชื่อธนาคาร
BANK_ACCOUNT_NUMBER=เลขบัญชี
BANK_ACCOUNT_NAME=ชื่อบัญชี
